[
  {
    "regex": "^(\\d{4}-\\d{4}) - (?:Zarakhuvannia|Vyplata).*?\\n([\\d.]+)\\s+(\\w+)\\n(?:Dostupno\\s+([\\d.]+).+?\\n)?(\\d{2}\\.\\d{2}\\s+\\d{2}:\\d{2})",
    "map": {
      "account": 1,
      "sum": 2,
      "currency": 3,
      "balance": 4,
      "datetime": 5
    }
  },
  {
    "regex": "^(\\d{4}-\\d{4}) - (?:Oplata|Spysannia)\\n([\\d.]+)\\s+(\\w+)(?:\\(([^)]+)\\))?\\n(?:Dostupno\\s+([\\d.]+).+?\\n)?(\\d{2}\\.\\d{2}\\s+\\d{2}:\\d{2})",
    "map": {
      "account": 1,
      "sum": -2,
      "currency": 3,
      "payee": 4,
      "balance": 5,
      "datetime": 6
    }
  }
]
